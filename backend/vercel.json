{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/.prisma/**",
          "node_modules/.pnpm/@prisma+client@5.22.0_prisma@5.22.0/node_modules/@prisma/client/**",
          "node_modules/.pnpm/prisma@5.22.0/node_modules/prisma/query-engine-*"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/index.ts"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "api/index.ts"
    }
  ]
}