{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "src/generated/prisma/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/index.ts"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "api/index.ts"
    }
  ]
}