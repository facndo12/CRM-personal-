generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WhatsAppConnectionStatus {
  DISCONNECTED
  CONNECTING
  PAIRING
  CONNECTED
  ERROR
}

model Workspace {
  id        String   @id @default(cuid())
  name      String   
  slug      String   @unique
  plan      String   @default("free")
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users WorkspaceUser[]
  contacts Contact[]
  pipelines Pipeline[]
  deals     Deal[]
  activities Activity[] 
  notes      Note[]
  webhooks   WebhookEndpoint[]  
  apiKeys    ApiKey[]           
  eventLogs  EventLog[]     
  channelConnections ChannelConnection[]
  contactIdentities  ContactIdentity[]
  conversations      Conversation[]
  messages           Message[]
  whatsappSessions   WhatsAppSession[]
  whatsappChats      WhatsAppChat[]
  whatsappMessages   WhatsAppMessage[]

  @@map("workspaces")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String?   
  avatar       String?   
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  workspaces WorkspaceUser[]

  @@map("users")
}

model WorkspaceUser {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("member")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_users")
}

model Contact {
  id          String    @id @default(cuid())
  workspaceId String
  firstName   String
  lastName    String?       
  email       String?       
  phone       String?       
  avatar      String?       
  status      String    @default("LEAD")
  source      String    @default("MANUAL")
  score       Int       @default(0)
  tags        String[]
  companyId   String?       
  ownerId     String?       
  channels    Json      @default("[]")
  customData  Json      @default("{}")
  isArchived  Boolean   @default(false)
  mergedInto  String?       
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastContactedAt DateTime?  

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deals     DealContact[]
  activities    Activity[] 
  notes      Note[]
  identities ContactIdentity[]
  conversations Conversation[]
  messages   Message[]
  whatsappChats WhatsAppChat[]

  @@index([workspaceId])
  @@index([workspaceId, email])
  @@index([workspaceId, phone])
  @@index([workspaceId, status])
  @@map("contacts")
}

model Pipeline {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages    Stage[]
  deals     Deal[]

  @@index([workspaceId])
  @@map("pipelines")
}

model Stage {
  id              String   @id @default(cuid())
  pipelineId      String
  name            String
  position        Int
  color           String   @default("#6366f1")
  probability     Int?              // ← agregar: probabilidad por defecto
  isWon           Boolean  @default(false)
  isLost          Boolean  @default(false)
  rottenAfterDays Int?              // ← agregar: días para marcar como podrido

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId, position])
  @@map("stages")
}

model Deal {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  value       Decimal?  @db.Decimal(15, 2)  
  currency    String    @default("USD")
  probability Int?                           
  pipelineId  String
  stageId     String
  position    Int       @default(0)
  companyId   String?                        
  ownerId     String?                        
  status      String    @default("OPEN")
  expectedCloseDate DateTime?
  isArchived  Boolean  @default(false)
  stageEnteredAt    DateTime  @default(now())
  closedAt          DateTime?               
  closedReason      String?                 
  customData  Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline  Pipeline      @relation(fields: [pipelineId], references: [id])
  stage     Stage         @relation(fields: [stageId], references: [id])
  contacts  DealContact[]
  activities  Activity[]   
  notes       Note[]

  @@index([workspaceId])
  @@index([workspaceId, stageId])
  @@index([workspaceId, status])
  @@map("deals")
}

model DealContact {
  dealId    String
  contactId String
  role      String?

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([dealId, contactId])
  @@map("deal_contacts")
}

model Activity {
  id          String   @id @default(cuid())
  workspaceId String
  type        String
  entityType  String
  entityId    String
  contactId   String?
  dealId      String?
  userId      String?
  source      String?
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact?  @relation(fields: [contactId], references: [id])
  deal      Deal?     @relation(fields: [dealId], references: [id])

  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, createdAt])
  @@map("activities")
}

model Note {
  id          String   @id @default(cuid())
  workspaceId String
  content     String
  entityType  String
  entityId    String
  contactId   String?
  dealId      String?
  userId      String?
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact?  @relation(fields: [contactId], references: [id])
  deal      Deal?     @relation(fields: [dealId], references: [id])

  @@index([workspaceId, entityType, entityId])
  @@map("notes")
}

model WhatsAppSession {
  id                  String                   @id @default(cuid())
  workspaceId         String                   @unique
  status              WhatsAppConnectionStatus @default(DISCONNECTED)
  phoneNumber         String?
  phoneJid            String?
  pushName            String?
  pairingCode         String?
  pairingCodeIssuedAt DateTime?
  qrCode              String?
  lastConnectedAt     DateTime?
  lastDisconnectedAt  DateTime?
  lastDisconnectCode  Int?
  lastError           String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chats     WhatsAppChat[]
  messages  WhatsAppMessage[]

  @@map("whatsapp_sessions")
}

model WhatsAppChat {
  id                 String   @id @default(cuid())
  workspaceId        String
  sessionId          String
  jid                String
  displayName        String?
  phoneNumber        String?
  isGroup            Boolean  @default(false)
  unreadCount        Int      @default(0)
  archived           Boolean  @default(false)
  pinned             Boolean  @default(false)
  mutedUntil         DateTime?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  lastMessageFromMe  Boolean?
  contactId          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  session   WhatsAppSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contact   Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages  WhatsAppMessage[]

  @@unique([workspaceId, jid])
  @@index([workspaceId, lastMessageAt])
  @@index([workspaceId, contactId])
  @@map("whatsapp_chats")
}

model WhatsAppMessage {
  id                   String   @id @default(cuid())
  workspaceId          String
  sessionId            String
  chatId               String
  remoteJid            String
  messageId            String
  fromMe               Boolean  @default(false)
  participant          String?
  pushName             String?
  messageType          String   @default("unknown")
  text                 String?
  status               String?
  mediaPath            String?
  mediaMimeType        String?
  mediaFileName        String?
  mediaSizeBytes       Int?
  mediaDurationSeconds Int?
  quotedMessageId      String?
  quotedText           String?
  quotedMessageType    String?
  sentAt               DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  session   WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chat      WhatsAppChat    @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, remoteJid, messageId])
  @@index([workspaceId, chatId, sentAt])
  @@index([workspaceId, remoteJid, sentAt])
  @@map("whatsapp_messages")
}

model WebhookEndpoint {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  url             String
  secret          String?
  events          String[]
  isActive        Boolean   @default(true)
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?
  lastStatusCode  Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("webhook_endpoints")
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model EventLog {
  id          String   @id @default(cuid())
  workspaceId String
  event       String
  payload     Json
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, event])
  @@index([workspaceId, createdAt])
  @@map("event_logs")
}

model ChannelConnection {
  id                   String   @id @default(cuid())
  workspaceId          String
  provider             String
  channel              String
  name                 String
  status               String   @default("disconnected")
  externalAccountId    String
  externalAccountLabel String?
  credentials          Json     @default("{}")
  settings             Json     @default("{}")
  lastSyncedAt         DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([workspaceId, channel])
  @@unique([workspaceId, channel, externalAccountId])
  @@map("channel_connections")
}

model ContactIdentity {
  id                  String   @id @default(cuid())
  workspaceId         String
  contactId           String
  provider            String
  channel             String
  externalUserId      String
  externalUsername    String?
  externalDisplayName String?
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@unique([workspaceId, channel, externalUserId])
  @@map("contact_identities")
}

model Conversation {
  id               String   @id @default(cuid())
  workspaceId      String
  connectionId     String
  contactId        String
  provider         String
  channel          String
  externalThreadId String?
  externalUserId   String?
  status           String   @default("open")
  inboxState       String   @default("active")
  unreadCount      Int      @default(0)
  lastInboundAt    DateTime?
  lastOutboundAt   DateTime?
  lastMessageAt    DateTime?
  assignedToUserId String?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection  ChannelConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([workspaceId, channel, lastMessageAt])
  @@index([contactId])
  @@unique([connectionId, contactId])
  @@map("conversations")
}

model Message {
  id                String   @id @default(cuid())
  workspaceId       String
  conversationId    String
  contactId         String?
  provider          String
  channel           String
  direction         String
  type              String   @default("text")
  status            String   @default("pending")
  providerMessageId String?  @unique
  providerReplyToId String?
  text              String?
  rawPayload        Json?
  metadata          Json     @default("{}")
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  attachments  MessageAttachment[]
  deliveries   MessageDelivery[]

  @@index([conversationId, createdAt])
  @@index([workspaceId, channel, createdAt])
  @@map("messages")
}

model MessageAttachment {
  id              String   @id @default(cuid())
  messageId        String
  type             String
  mimeType         String?
  url              String?
  externalAssetId  String?
  fileName         String?
  sizeBytes        Int?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

model MessageDelivery {
  id                String   @id @default(cuid())
  messageId          String
  providerMessageId String?
  providerStatus    String
  providerTimestamp DateTime?
  errorCode         String?
  errorMessage      String?
  rawPayload        Json?
  createdAt         DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([providerMessageId])
  @@map("message_deliveries")
}
