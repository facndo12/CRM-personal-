{
  "name": "crm-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter crm dev\" \"pnpm --filter frontend dev\"",
    "dev:backend": "pnpm --filter crm dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm --filter crm build && pnpm --filter frontend build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.23.8"
    }
  }
}